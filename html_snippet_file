                <input type="hidden" name="appLinkName" value="<%=zoho.appname%>">
                <input type="hidden" name="pageLinkName" value="Test_Page">
                <input type="hidden" name="viewType" value="page">
                <input type="hidden" name="d" value="<%=baseDate.toString("dd-MMM-yyyy")%>">
                <input type="hidden" name="emp" value="<%=searchQuery%>">
                <input type="hidden" name="landscape" value="true">
                <a href="https://creatorapp.zoho.in/export/zentegraindia/attendance-payroll-management/pdf/Test_Page?d=<%=baseDate.toString("yyyy-MM-dd")%>&emp=<%=searchQuery%>" class="text-decoration-none">
                    <button type="button" class="view-toggle-btn-custom"><i class="fas fa-file-pdf"></i> Export PDF</button>
                </a>
            </form>
        </div>
    </nav>

    <!-- LAYER 2: LEGEND -->
    <div class="legend-bar">
        <div class="legend-item"><span class="legend-chip status-fd" style="color:#fff;">P</span>Full Day Present (&ge; 8 Hrs / Friday &ge; 7 Hrs)</div>
        <div class="legend-item"><span class="legend-chip status-hd">HD</span>Half Day (&ge; 4 Hrs)</div>
        <div class="legend-item"><span class="legend-chip status-absent">A</span>Absent (&lt; 4 Hrs)</div>
        <div class="legend-item"><span class="legend-chip status-leave-sick">SL</span>Sick Leave</div>
        <div class="legend-item"><span class="legend-chip status-leave-casual">CL</span>Casual Leave</div>
        <div class="legend-item"><span class="legend-chip status-cl1">CL1</span>CL 1st</div>
        <div class="legend-item"><span class="legend-chip status-cl2">CL2</span>CL 2nd</div>
        <div class="legend-item"><span class="legend-chip status-lop">LOP</span>Loss of Pay</div>
        <div class="legend-item"><span class="legend-chip status-w">W</span>Weekend Off</div>
        <div class="legend-item"><span class="text-muted" style="margin-right:4px; font-weight:bold;">—</span>Future Date</div>
    </div>

    <!-- LAYER 3: SCROLLABLE TABLE -->
    <div class="main-content">
        <div class="table-wrapper" id="tableWrapper">
            <table class="attendance-table">
                <thead>
                    <tr>
                        <th class="employee-header"><b>Employee Name</b></th>
<%
	for each  dayIdx in manual_days
	{
		if(dayIdx < lastDayOfMonth)
		{
			iterDate = baseDate.addDay(dayIdx);
			dayOfWeekName = iterDate.toString("EEE");
			isWeekend = dayOfWeekName == "Sat" || dayOfWeekName == "Sun";
			%>
<th class="<%=if(isWeekend,"weekend-col","")%>">
                            <span class="date-num"><%=iterDate.toString("dd")%></span>
                            <span class="day-name"><%=dayOfWeekName%></span>
                        </th>
<%
		}
	}
	%>
<th class="total-header first-total"><span class="total-label">Present</span><span class="total-sub">Total</span></th>
                        <th class="total-header"><span class="total-label">Absent</span><span class="total-sub">Total</span></th>
                        <th class="total-header"><span class="total-label">Half Day</span><span class="total-sub">Total</span></th>
                        <th class="total-header sl-header"><span class="total-label">Sick Leave</span><span class="total-sub">SL Count</span></th>
                        <th class="total-header cl-header"><span class="total-label">Casual Leave</span><span class="total-sub">CL Count</span></th>
                        <th class="total-header lop-header"><span class="total-label">LOP</span><span class="total-sub">Loss of Pay</span></th>
                        <th class="total-header absent-header"><span class="total-label">Full Day Absent</span><span class="total-sub">No Leave</span></th>
                    </tr>
                </thead>
                <tbody>
<%
	for each  name in emp_names
	{
		rowPresent = 0.0;
		rowAbsent = 0.0;
		rowHalfDay = 0;
		rowSL = 0;
		rowCL = 0;
		rowLOP = 0;
		rowPureAbsent = 0;
		%>
<tr>
                        <td class="employee-cell">
                            <div class="employee-info">
                                <img src="https://ui-avatars.com/api/?name=<%=zoho.encryption.urlEncode(name)%>&background=4361ee&color=fff&size=80" alt="<%=name%>" class="employee-avatar">
                                <div class="employee-details"><span class="employee-name"><%=name%></span></div>
                            </div>
                        </td>
<%
		for each  dayIdx in manual_days
		{
			if(dayIdx < lastDayOfMonth)
			{
				checkDate = baseDate.addDay(dayIdx);
				dayNameString = checkDate.toString("EEE");
				isWE = dayNameString == "Sat" || dayNameString == "Sun";
				isFri = dayNameString == "Fri";
				isFuture = checkDate > today;
				daily_att = Attendance[Employee.Name == name && Date_field == checkDate];
				dateKey = name + "|" + checkDate.toString("yyyy-MM-dd");
				leaveInfo = zenfirm_leaves.get(dateKey);
				hasLeave = false;
				leaveType = "";
				leaveDayType = "";
				if(leaveInfo != null)
				{
					hasLeave = true;
					leaveType = leaveInfo.get("leave_type");
					leaveDayType = leaveInfo.get("day_type");
				}
				displayLeaveType = leaveType;
				if(leaveType == "CL")
				{
					monthKey = name + "|" + checkDate.toString("yyyy-MM");
					if(cl_dates_tracker.contains(monthKey))
					{
						clDates = cl_dates_tracker.get(monthKey);
						clIndex = clDates.indexOf(checkDate.toString("yyyy-MM-dd"));
						if(clIndex >= 0)
						{
							clNum = clIndex + 1;
							displayLeaveType = "CL " + clNum;
						}
					}
				}
				displayStatus = "";
				badgeClass = "";
				titleText = "";
				%>
<td class="<%=if(isWE,"weekend-col","")%>">
<%
				if(isWE)
				{
					%>
<span class="status-badge status-w" title="Weekend">W</span>
<%
				}
				else if(isFuture)
				{
					%>
<span class="text-muted" style="opacity: 0.4; font-weight: bold; font-size: 12px;">—</span>
<%
				}
				else if(daily_att.count() > 0)
				{
					hoursWorked = 0.0;
					for each  att in daily_att
					{
						if(att.Final_Hours_Worked != null)
						{
							hoursWorked = att.Final_Hours_Worked;
						}
					}
					requiredPresentHours = if(isFri,8.0,8.0);
					if(hoursWorked >= requiredPresentHours)
					{
						rowPresent = rowPresent + 1;
						%>
<span class="status-badge status-fd" title="Full Day Present (<%=hoursWorked%> hrs)">P</span>
<%
					}
					else if(hoursWorked >= 4)
					{
						rowPresent = rowPresent + 0.5;
						rowAbsent = rowAbsent + 0.5;
						rowHalfDay = rowHalfDay + 1;
						if(hasLeave)
						{
							displayStatus = displayLeaveType;
							titleText = "Half Day + " + displayLeaveType + " (" + hoursWorked + " hrs)";
							if(leaveType == "SL")
							{
								badgeClass = "status-leave-sick";
								rowSL = rowSL + 1;
							}
							else if(leaveType == "LOP")
							{
								badgeClass = "status-lop";
								rowLOP = rowLOP + 1;
							}
							else if(leaveType == "CL")
							{
								if(displayLeaveType == "CL 1")
								{
									badgeClass = "status-cl1";
								}
								else if(displayLeaveType == "CL 2")
								{
									badgeClass = "status-cl2";
								}
								else
								{
									badgeClass = "status-leave-casual";
								}
								rowCL = rowCL + 1;
							}
							else
							{
								badgeClass = "status-hd";
							}
						}
						else
						{
							// Build dynamic URL with employee filter and date filter
							id = emp.Employee.ID;
							attend_emo_obj = Attendance[Employee.Name == name];
							empName = name;
							dateFormatted = checkDate.toString("dd-MMM-yyyy");
							// 							// 1. Get the time string from your Date-Time field
							// 							timeString = input.Date_Time_Field.toString("HH:mm:ss");
							// 							// 2. Convert and map it directly into your Time field
							// 							input.Time_Field = timeString.toTime("HH:mm:ss");
							// If Punch_Time is a DateTime field
							// 							time = "GET_ZOHO_DATE_TIME_FIELD_HERE";
							// 							timeReformat = zohoDateTime.replaceAll("T"," ");
							// 							punchDateTime = emp.Punches.Punch_Time.getTime(12, true);         // Single record
							emp_punch = Attendance[Date_field == checkDate.toString("dd-MMM-yyyy") && Employee == attend_emo_obj.Employee];
							punchDateTime = emp_punch.Punches.Punch_Time.get(0).getTime(12,true);
							hdreporturl = "https://creatorapp.zoho.in/zentegraindia/attendance-payroll-management#Form:Attendance_Regularization?zc_LoadIn=dialog&Employee=" + attend_emo_obj.Employee + "&Date_field=" + checkDate.toString("dd-MMM-yyyy") + "&From_Time=" + punchDateTime;
							displayStatus = "HD";
							badgeClass = "status-hd";
							titleText = "Half Day - " + name + " on " + dateFormatted + " (" + hoursWorked + " hrs) - Click to view report";
							%>
<a href="<%=hdreporturl%>" 
						   onclick="window.open(this.href, 'HDReportPopup_<%=name%>_<%=dateFormatted%>', 'width=100,height=700,left=200,top=100,scrollbars=yes,resizable=yes,toolbar=no,menubar=no,location=no,status=no'); return false;" 
						   class="hd-link"
						   title="<%=titleText%>"
						   style="cursor: pointer; text-decoration: none;">
							<span class="status-badge status-hd">HD</span>
						</a>
<%
						}
					}
					else
					{
						rowAbsent = rowAbsent + 1;
						if(hasLeave)
						{
							displayStatus = displayLeaveType;
							titleText = "Leave: " + displayLeaveType + " (" + hoursWorked + " hrs)";
							if(leaveType == "SL")
							{
								badgeClass = "status-leave-sick";
								rowSL = rowSL + 1;
							}
							else if(leaveType == "LOP")
							{
								badgeClass = "status-lop";
								rowLOP = rowLOP + 1;
							}
							else if(leaveType == "CL")
							{
								if(displayLeaveType == "CL 1")
								{
									badgeClass = "status-cl1";
								}
								else if(displayLeaveType == "CL 2")
								{
									badgeClass = "status-cl2";
								}
								else
								{
									badgeClass = "status-leave-casual";
								}
								rowCL = rowCL + 1;
							}
							else
							{
								badgeClass = "status-absent";
							}
						}
						else
						{
							displayStatus = "A";
							badgeClass = "status-absent";
							titleText = "Absent (" + hoursWorked + " hrs)";
							rowPureAbsent = rowPureAbsent + 1;
						}
						%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
					}
				}
				else
				{
					rowAbsent = rowAbsent + 1;
					if(hasLeave)
					{
						displayStatus = displayLeaveType;
						titleText = "Leave: " + displayLeaveType;
						if(leaveType == "SL")
						{
							badgeClass = "status-leave-sick";
							rowSL = rowSL + 1;
						}
						else if(leaveType == "LOP")
						{
							badgeClass = "status-lop";
							rowLOP = rowLOP + 1;
						}
						else if(leaveType == "CL")
						{
							if(displayLeaveType == "CL 1")
							{
								badgeClass = "status-cl1";
							}
							else if(displayLeaveType == "CL 2")
							{
								badgeClass = "status-cl2";
							}
							else
							{
								badgeClass = "status-leave-casual";
							}
							rowCL = rowCL + 1;
						}
						else
						{
							badgeClass = "status-absent";
						}
					}
					else
					{
						displayStatus = "A";
						badgeClass = "status-absent";
						titleText = "Absent";
						rowPureAbsent = rowPureAbsent + 1;
					}
					%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
				}
				%>
</td>
<%
			}
		}
		%>
<td class="total-cell first-total"><span class="total-value total-present"><%=rowPresent%></span></td>
                        <td class="total-cell"><span class="total-value total-absent"><%=rowAbsent%></span></td>
                        <td class="total-cell"><span class="total-value total-hd-count"><%=rowHalfDay%></span></td>
                        <td class="total-cell sl-cell"><span class="total-value total-sl"><%=rowSL%></span></td>
                        <td class="total-cell cl-cell"><span class="total-value total-cl"><%=rowCL%></span></td>
                        <td class="total-cell lop-cell"><span class="total-value total-lop"><%=rowLOP%></span></td>
                        <td class="total-cell absent-only-cell"><span class="total-value total-absent-only"><%=rowPureAbsent%></span></td>
                    </tr>
<%
	}
	%>
</tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- ============================================================
         JAVASCRIPT FIX FOR ZOHO IFRAME HEIGHT
         Forces body to use actual visible height instead of broken 100%
         This makes sticky headers work properly inside Zoho
    ============================================================ -->
    <script>
        function fixLayoutHeight() {
            // Force body height to viewport height
            document.documentElement.style.height = window.innerHeight + 'px';
            document.body.style.height = window.innerHeight + 'px';
        }
        
        // Run on load
        fixLayoutHeight();
        
        // Run after a small delay (Zoho iframe may resize)
        setTimeout(fixLayoutHeight, 100);
        setTimeout(fixLayoutHeight, 500);
        setTimeout(fixLayoutHeight, 1000);
        
        // Run on window resize
        window.addEventListener('resize', fixLayoutHeight);
        
        // Run on orientation change (mobile)
        window.addEventListener('orientationchange', fixLayoutHeight);
    </script>
</body>
</html>
<%

}%>

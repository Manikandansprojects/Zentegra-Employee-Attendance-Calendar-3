        .nav-center { display: flex; align-items: center; gap: 15px; }
        .month-nav { display: flex; align-items: center; gap: 8px; }
        .month-nav-btn { width: 34px; height: 34px; border: 1px solid #1b355a; background: #1b355a; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #fff; transition: all 0.2s; }

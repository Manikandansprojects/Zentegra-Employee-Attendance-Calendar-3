        <!-- NAVBAR -->
        <nav class="top-navbar">
            <div class="nav-left">
                <ul class="breadcrumb-custom"><li><h3 style="margin:0;"><b>Employee Attendance Calendar</b></h3></li></ul>
            </div>
            <div class="nav-center">
                <div class="month-nav">
                    <a href="#Page:Test_Page?d=<%=prevMonth%>&emp=<%=searchQuery%>" class="month-nav-btn text-decoration-none"><i class="fas fa-chevron-left"></i></a>
                    <span class="current-month"><%=baseDate.toString("MMMM yyyy")%></span>
                    <a href="#Page:Test_Page?d=<%=nextMonth%>&emp=<%=searchQuery%>" class="month-nav-btn text-decoration-none"><i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
            <div class="nav-right">
                <form action="/printpdf.do" method="get" target="_blank" style="margin: 0; padding: 0; display: inline-block;">
                    <input type="hidden" name="sharedBy" value="<%=zoho.adminuser%>">
                    <input type="hidden" name="appLinkName" value="<%=zoho.appname%>">
                    <input type="hidden" name="pageLinkName" value="Test_Page">
                    <input type="hidden" name="viewType" value="page">
                    <input type="hidden" name="d" value="<%=baseDate.toString("dd-MMM-yyyy")%>">
                    <input type="hidden" name="emp" value="<%=searchQuery%>">
                    <input type="hidden" name="landscape" value="true">
                    <a href="https://creatorapp.zoho.in/export/zentegraindia/attendance-payroll-management/pdf/Test_Page?d=<%=baseDate.toString("yyyy-MM-dd")%>&emp=<%=searchQuery%>" class="text-decoration-none">
                        <button type="button" class="view-toggle-btn-custom"><i class="fas fa-file-pdf"></i> Export PDF</button>
                    </a>
                </form>
            </div>
        </nav>

        <!-- LEGEND -->
        <div class="legend-bar">
            <div class="legend-item"><span class="legend-chip status-fd">P</span>Full Day Present (&ge; 8 Hrs)</div>
            <div class="legend-item"><span class="legend-chip status-lh">LHW</span>Low Hours Worked (&lt; 8 Hrs)</div>
            <div class="legend-item"><span class="legend-chip status-absent">A</span>Absent (0 Hrs)</div>
            <div class="legend-item"><span class="legend-chip status-leave-casual">CL</span>CL Full</div>
            <div class="legend-item"><span class="legend-chip status-cl1">CL 1st</span>CL 1st Half</div>
            <div class="legend-item"><span class="legend-chip status-cl2">CL 2nd</span>CL 2nd Half</div>
            <div class="legend-item"><span class="legend-chip status-leave-sick">SL</span>Sick Leave Full</div>
            <div class="legend-item"><span class="legend-chip status-sl1">SL 1st</span>Sick Leave 1st Half</div>
            <div class="legend-item"><span class="legend-chip status-sl2">SL 2nd</span>Sick Leave 2nd Half</div>
            <div class="legend-item"><span class="legend-chip status-lop1">LOP 1st</span>LOP 1st Half</div>
            <div class="legend-item"><span class="legend-chip status-lop2">LOP 2nd</span>LOP 2nd Half</div>
            <div class="legend-item"><span class="legend-chip status-lop">LOP</span>LOP Full Day</div>
            <div class="legend-item"><span class="legend-chip status-w">W</span>Weekend Off</div>
            <div class="legend-item"><span class="text-muted" style="margin-right:4px; font-weight:bold;">—</span>Future Date</div>
        </div>
    </div>

    <!-- SCROLLABLE TABLE -->
    <div class="table-container" id="tableContainer">
        <table class="attendance-table">
            <thead>
                <tr>
                    <th class="employee-header"><b>Employee Name</b></th>
<%
	for each  dayIdx in manual_days
	{
		if(dayIdx < lastDayOfMonth)
		{
			iterDate = baseDate.addDay(dayIdx);
			dayOfWeekName = iterDate.toString("EEE");
			isWeekend = dayOfWeekName == "Sat" || dayOfWeekName == "Sun";
			%>
<th class="<%=if(isWeekend,"weekend-col","")%>">
                            <span class="date-num"><%=iterDate.toString("dd")%></span>
                            <span class="day-name"><%=dayOfWeekName%></span>
                        </th>
<%
		}
	}
	%>
<th class="total-header first-total"><span class="total-label">Present</span><span class="total-sub">Total</span></th>
                    <th class="total-header"><span class="total-label">Absent</span><span class="total-sub">Total</span></th>
                    <th class="total-header"><span class="total-label">Half Day</span><span class="total-sub">Total</span></th>
                    <th class="total-header sl-header"><span class="total-label">Sick Leave</span><span class="total-sub">SL Count</span></th>
                    <th class="total-header cl-header"><span class="total-label">Casual Leave</span><span class="total-sub">CL Count</span></th>
                    <th class="total-header lop-header"><span class="total-label">LOP</span><span class="total-sub">Loss of Pay</span></th>
                    <th class="total-header absent-header"><span class="total-label">Full Day Absent</span><span class="total-sub">No Leave</span></th>
                </tr>
            </thead>
            <tbody>
<%
	for each  name in emp_names
	{
		rowPresent = 0.0;
		rowAbsent = 0.0;
		rowHalfDay = 0;
		rowSL = 0.0;
		rowCL = 0.0;
		rowLOP = 0.0;
		rowPureAbsent = 0.0;
		%>
<tr>
                    <td class="employee-cell">
                        <div class="employee-info">
                            <img src="https://ui-avatars.com/api/?name=<%=zoho.encryption.urlEncode(name)%>&background=4361ee&color=fff&size=80" alt="<%=name%>" class="employee-avatar">
                            <div class="employee-details"><span class="employee-name"><%=name%></span></div>
                        </div>
                    </td>
<%
		for each  dayIdx in manual_days
		{
			if(dayIdx < lastDayOfMonth)
			{
				checkDate = baseDate.addDay(dayIdx);
				dayNameString = checkDate.toString("EEE");
				isWE = dayNameString == "Sat" || dayNameString == "Sun";
				isFuture = checkDate > today;
				daily_att = Attendance[Employee.Name == name && Date_field == checkDate];
				dateKey = name + "|" + checkDate.toString("yyyy-MM-dd");
				leaveInfo = zenfirm_leaves.get(dateKey);
				hasLeave = false;
				leaveType = "";
				leaveDayType = "";
				isHalfDay = false;
				isFH = false;
				isSH = false;
				
				if(leaveInfo != null)
				{
					hasLeave = true;
					leaveType = leaveInfo.get("leave_type");
					leaveDayType = leaveInfo.get("day_type");
					brVal = ifnull(leaveInfo.get("br"),"");
					brLower = brVal.toLowerCase();
					dayTypeLower = ifnull(leaveDayType,"").toLowerCase();
					
					if(brLower.contains("First Half") || brLower.contains("1st") || brLower.contains("fh"))
					{
						isHalfDay = true;
						isFH = true;
					}
					else if(brLower.contains("Second Half") || brLower.contains("2nd") || brLower.contains("sh"))
					{
						isHalfDay = true;
						isSH = true;
					}
					else if(dayTypeLower.contains("half"))
					{
						isHalfDay = true;
						isFH = true;
					}
				}
				
				displayStatus = "";
				badgeClass = "";
				titleText = "";
				%>
<td class="<%=if(isWE,"weekend-col","")%>">
<%
				if(isWE)
				{
					%>
<span class="status-badge status-w" title="Weekend">W</span>
<%
				}
				else if(isFuture)
				{
					%>
<span class="text-muted" style="opacity: 0.4; font-weight: bold; font-size: 12px;">—</span>
<%
				}
				else if(daily_att.count() > 0)
				{
					hoursWorked = 0.0;
					for each  att in daily_att
					{
						if(att.Final_Hours_Worked != null)
						{
							hoursWorked = att.Final_Hours_Worked;
						}
					}
					
					if(hoursWorked >= 8.0)
					{
						rowPresent = rowPresent + 1;
						%>
<span class="status-badge status-fd" title="Full Day Present (<%=hoursWorked%> hrs)">P</span>
<%
					}
					else
					{
						if(hasLeave && isHalfDay)
						{
							if(hoursWorked >= 4.0)
							{
								rowPresent = rowPresent + 0.5;
								rowAbsent = rowAbsent + 0.5;
								rowHalfDay = rowHalfDay + 1;
								leaveIncrement = 0.5;
								
								if(leaveType == "SL")
								{
									if(isFH) { displayStatus = "SL 1st"; badgeClass = "status-sl1"; }
									else { displayStatus = "SL 2nd"; badgeClass = "status-sl2"; }
									rowSL = rowSL + leaveIncrement;
								}
								else if(leaveType == "LOP")
								{
									if(isFH) { displayStatus = "LOP 1st"; badgeClass = "status-lop1"; }
									else { displayStatus = "LOP 2nd"; badgeClass = "status-lop2"; }
									rowLOP = rowLOP + leaveIncrement;
								}
								else
								{
									if(isFH) { displayStatus = "CL 1st"; badgeClass = "status-cl1"; }
									else { displayStatus = "CL 2nd"; badgeClass = "status-cl2"; }
									rowCL = rowCL + leaveIncrement;
								}
								titleText = displayStatus + " + Worked (" + hoursWorked + " hrs)";
							}
							else
							{
								rowAbsent = rowAbsent + 1.0;
								rowPureAbsent = rowPureAbsent + 0.5;
								leaveIncrement = 0.5;
								
								if(leaveType == "SL")
								{
									if(isFH) { displayStatus = "SL 1st"; badgeClass = "status-sl1"; }
									else { displayStatus = "SL 2nd"; badgeClass = "status-sl2"; }
									rowSL = rowSL + leaveIncrement;
								}
								else if(leaveType == "LOP")
								{
									if(isFH) { displayStatus = "LOP 1st"; badgeClass = "status-lop1"; }
									else { displayStatus = "LOP 2nd"; badgeClass = "status-lop2"; }
									rowLOP = rowLOP + leaveIncrement;
								}
								else
								{
									if(isFH) { displayStatus = "CL 1st"; badgeClass = "status-cl1"; }
									else { displayStatus = "CL 2nd"; badgeClass = "status-cl2"; }
									rowCL = rowCL + leaveIncrement;
								}
								titleText = displayStatus + " + Half Day Absent (Worked " + hoursWorked + " hrs)";
							}
							%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
						}
						else if(hasLeave && !isHalfDay)
						{
							rowAbsent = rowAbsent + 1.0;
							if(leaveType == "SL")
							{
								displayStatus = "SL";
								badgeClass = "status-leave-sick";
								rowSL = rowSL + 1.0;
							}
							else if(leaveType == "LOP")
							{
								displayStatus = "LOP";
								badgeClass = "status-lop";
								rowLOP = rowLOP + 1.0;
							}
							else
							{
								displayStatus = "CL";
								badgeClass = "status-leave-casual";
								rowCL = rowCL + 1.0;
							}
							titleText = displayStatus + " Full Day Leave (Worked " + hoursWorked + " hrs)";
							%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
						}
						else
						{
							if(hoursWorked >= 4.0)
							{
								rowPresent = rowPresent + 0.5;
								rowAbsent = rowAbsent + 0.5;
								rowHalfDay = rowHalfDay + 1;
							}
							else
							{
								rowAbsent = rowAbsent + 1.0;
								rowPureAbsent = rowPureAbsent + 1.0;
							}
							displayStatus = "LHW";
							badgeClass = "status-lh";
							titleText = "Low Work Hours (" + hoursWorked + " hrs)";
							%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
						}
					}
				}
				else
				{
					if(hasLeave)
					{
						if(isHalfDay)
						{
							rowAbsent = rowAbsent + 1.0;
							rowPureAbsent = rowPureAbsent + 0.5;
							leaveIncrement = 0.5;
							
							if(leaveType == "SL")
							{
								if(isFH) { displayStatus = "SL 1st"; badgeClass = "status-sl1"; }
								else { displayStatus = "SL 2nd"; badgeClass = "status-sl2"; }
								rowSL = rowSL + leaveIncrement;
							}
							else if(leaveType == "LOP")
							{
								if(isFH) { displayStatus = "LOP 1st"; badgeClass = "status-lop1"; }
								else { displayStatus = "LOP 2nd"; badgeClass = "status-lop2"; }
								rowLOP = rowLOP + leaveIncrement;
							}
							else
							{
								if(isFH) { displayStatus = "CL 1st"; badgeClass = "status-cl1"; }
								else { displayStatus = "CL 2nd"; badgeClass = "status-cl2"; }
								rowCL = rowCL + leaveIncrement;
							}
							titleText = displayStatus + " + Half Day Absent";
						}
						else
						{
							rowAbsent = rowAbsent + 1.0;
							if(leaveType == "SL")
							{
								displayStatus = "SL";
								badgeClass = "status-leave-sick";
								rowSL = rowSL + 1.0;
							}
							else if(leaveType == "LOP")
							{
								displayStatus = "LOP";
								badgeClass = "status-lop";
								rowLOP = rowLOP + 1.0;
							}
							else
							{
								displayStatus = "CL";
								badgeClass = "status-leave-casual";
								rowCL = rowCL + 1.0;
							}
							titleText = displayStatus + " Full Day Leave";
						}
						%>
<span class="status-badge <%=badgeClass%>" title="<%=titleText%>"><%=displayStatus%></span>
<%
					}
					else
					{
						rowAbsent = rowAbsent + 1.0;
						rowPureAbsent = rowPureAbsent + 1.0;
						%>
<span class="status-badge status-absent" title="Absent">A</span>
<%
					}
				}
				%>
</td>
<%
			}
		}
		%>
<td class="total-cell first-total"><span class="total-value total-present"><%=rowPresent%></span></td>
                    <td class="total-cell"><span class="total-value total-absent"><%=rowAbsent%></span></td>
                    <td class="total-cell"><span class="total-value total-hd-count"><%=rowHalfDay%></span></td>
                    <td class="total-cell sl-cell"><span class="total-value total-sl"><%=rowSL%></span></td>
                    <td class="total-cell cl-cell"><span class="total-value total-cl"><%=rowCL%></span></td>
                    <td class="total-cell lop-cell"><span class="total-value total-lop"><%=rowLOP%></span></td>
                    <td class="total-cell absent-only-cell"><span class="total-value total-absent-only"><%=rowPureAbsent%></span></td>
                </tr>
<%
	}
	%>
</tbody>
        </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        function fixLayout() {
            // Get header height
            var headerHeight = document.querySelector('.header-container').offsetHeight;
            // Set table container height
            var tableContainer = document.querySelector('.table-container');
            tableContainer.style.height = 'calc(100vh - ' + headerHeight + 'px)';
        }
        
        // Run on load and resize
        window.addEventListener('load', fixLayout);
        window.addEventListener('resize', fixLayout);
        setTimeout(fixLayout, 100);
        setTimeout(fixLayout, 300);
        setTimeout(fixLayout, 500);
    </script>
</body>
</html>
<%

}%>
